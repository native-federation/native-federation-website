---
import LandingPage from '../layouts/LandingPage.astro';

const title = 'Team — Native Federation';
const description =
	'Meet the team behind Native Federation — the people building the future of browser-native Micro Frontends.';
---

<LandingPage
	title={title}
	description={description}
	canonical="https://native-federation.com/team/"
	ogType="website"
	twitterDescription="Meet the team behind Native Federation."
	activePage="team"
>
	<section class="page-hero">
		<span class="section-label">People</span>
		<h1>Meet the Team</h1>
		<p>
			The people behind Native Federation — building the future of browser-native Micro Frontends.
		</p>
	</section>

	<!-- Core Team -->
	<section class="section">
		<div class="section-header advisory-header">
			<span class="section-label">Core Team</span>
			<h2>Leadership</h2>
		</div>

		<div class="team-grid">
			<div class="team-card">
				<img src="/images/auke.jpeg" alt="Auke van Oostenbrugge" class="team-photo" width="96" height="96" />
				<div class="team-info">
					<h3>Auke van Oostenbrugge</h3>
					<div class="team-role">Project Lead</div>
					<p class="team-bio">
						Native Federation maintainer, MSc in Advanced Software Development, and Frontend R&amp;D Software
						Engineer at ParnasSys. Drives the daily development and evolution of the Native Federation
						ecosystem.
					</p>
				</div>
			</div>

			<div class="team-card">
				<img src="/images/manfred.jpg" alt="Manfred Steyer" class="team-photo" width="96" height="96" />
				<div class="team-info">
					<h3>Manfred Steyer</h3>
					<div class="team-role">Founder</div>
					<p class="team-bio">
						Trainer, consultant, and programming architect with a focus on Angular. Google Developer Expert
						(GDE) who writes for O'Reilly, the German Java Magazine, and windows.developer. A regular speaker
						at international conferences.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Advisory Board -->
	<section class="section section-alt">
		<div class="section-header advisory-header">
			<span class="section-label">Advisory Board</span>
			<h2>Industry Advisors</h2>
			<p>
				The advisory board consists of senior engineers and architects from leading companies using Native
				Federation in large-scale production environments:<br /><br /><span class="advisory-companies"
					>Siemens Energy &ensp;&middot;&ensp; BMW &ensp;&middot;&ensp; Dutch Railways &ensp;&middot;&ensp;
					DAZN &ensp;&middot;&ensp; Santander &ensp;&middot;&ensp; Sanitas &ensp;&middot;&ensp; Topicus</span
				>
			</p>
		</div>

		<div class="advisory-grid">
			<div class="advisory-card">
				<img src="/images/advisory/alexander-bock.jpg" alt="Alexander Bock" class="advisory-avatar" width="96" height="96" loading="lazy" />
				<h4>Alexander Bock</h4>
				<p class="advisory-summary">
					Built Micro Frontend architectures at Deutsches Zahnärztliches Rechenzentrum and brings 10 years of
					Angular experience.
				</p>
			</div>

			<div class="advisory-card">
				<img src="/images/advisory/peter-eijgermans.jpg" alt="Peter Eijgermans" class="advisory-avatar" width="96" height="96" loading="lazy" />
				<h4>Peter Eijgermans</h4>
				<p class="advisory-summary">
					Used Native Federation for Dutch Railways and shares that hands-on experience in workshops and
					conference talks.
				</p>
			</div>

			<div class="advisory-card">
				<img src="/images/advisory/lutz-leonhardt.jpg" alt="Lutz Leonhardt" class="advisory-avatar" width="96" height="96" loading="lazy" />
				<h4>Lutz Leonhardt</h4>
				<p class="advisory-summary">
					Helped migrate Siemens Energy's Angular Micro Frontend landscape from Module Federation to Native
					Federation across 15 teams.
				</p>
			</div>

			<div class="advisory-card">
				<img src="/images/advisory/victor-magalhaes.jpg" alt="Victor Magalhaes" class="advisory-avatar" width="96" height="96" loading="lazy" />
				<h4>Victor Magalhaes</h4>
				<p class="advisory-summary">
					Was responsible for BMW's federation-based Micro Frontend architecture spanning 70+ teams and
					evaluated Native Federation alongside Module Federation.
				</p>
			</div>

			<div class="advisory-card">
				<img src="/images/advisory/luca-mezzalira.png" alt="Luca Mezzalira" class="advisory-avatar" width="96" height="96" loading="lazy" />
				<h4>Luca Mezzalira</h4>
				<p class="advisory-summary">
					Designed DAZN's Micro Frontend architecture, is a well-known O'Reilly author for Micro Frontends,
					and previously worked at Amazon.
				</p>
			</div>

			<div class="advisory-card">
				<img src="/images/alejandro.jpg" alt="Alejandro Ramirez Jimenez" class="advisory-avatar" width="96" height="96" loading="lazy" />
				<h4>Alejandro Ramirez Jimenez</h4>
				<p class="advisory-summary">
					Worked with Module Federation and Native Federation for 4+ years across large healthcare and
					banking projects at Sanitas and Santander.
				</p>
			</div>

			<div class="advisory-card">
				<img src="/images/advisory/florian-rappl.png" alt="Florian Rappl" class="advisory-avatar" width="96" height="96" loading="lazy" />
				<h4>Florian Rappl</h4>
				<p class="advisory-summary">
					Early Micro Frontend pioneer who introduced bundler-independent and framework-agnostic approaches.
					Helped dozens of companies with hundreds of teams successfully scale their frontend architectures.
				</p>
			</div>

			<div class="advisory-card">
				<img src="/images/advisory/davide-senatore.jpg" alt="Davide Senatore" class="advisory-avatar" width="96" height="96" loading="lazy" />
				<h4>Davide Senatore</h4>
				<p class="advisory-summary">
					Built a large-scale platform on Native Federation for federated Micro Frontend applications. Regular
					conference speaker and trainer on Micro Frontend topics.
				</p>
			</div>

			<div class="advisory-card">
				<img src="/images/advisory/yannik-wieler.jpg" alt="Yannik Wieler" class="advisory-avatar" width="96" height="96" loading="lazy" />
				<h4>Yannik Wieler</h4>
				<p class="advisory-summary">
					Drives DZR's (Deutsches Zahnärztliches Rechenzentrum) Micro Frontend architecture since 2019 and
					currently leads its migration to Native Federation.
				</p>
			</div>
		</div>
	</section>
</LandingPage>
